---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { ongoingProjects, finishedProjects } from "../data/projects";

const sections = [
  { title: "Ongoing", items: ongoingProjects },
  { title: "Finished", items: finishedProjects },
];
---

<BaseLayout title="Jiyu Lee: Projects" sideBarActiveItemID="projects">
  {
    sections.map((section, sIdx) => (
      <>
        <div>
          <div class={`text-3xl w-full font-bold mb-5 ${sIdx > 0 ? "mt-10" : ""}`}>
            {section.title}
          </div>
        </div>
        {section.items.map((project, i) => (
          <>
            <HorizontalCard
              title={project.title}
              img={project.img}
              desc={project.desc}
              url={project.url}
              badge={project.badge}
            />
            {i < section.items.length - 1 && <div class="divider my-0" />}
          </>
        ))}
      </>
    ))
  }
</BaseLayout>
