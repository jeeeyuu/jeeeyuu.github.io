---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"
import { ongoingProjects as projects } from "../data/projects";
import { usefulPrograms, bioinformaticsPipelines, bioinformaticsTools } from "../data/products";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest_post = posts[0];

const allProducts = [...usefulPrograms, ...bioinformaticsPipelines, ...bioinformaticsTools];
const latest_product = allProducts[allProducts.length - 1];
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">🐈🐈‍⬛ I'm a Bio-data Scientist 🐈🐈‍⬛</div>
    <div class="text-5xl font-bold">Jiyu Lee</div>
    <div class="text-3xl py-3">A Journey toward Neurodevelopmental Disease Diagnosis Solutions</div>
    <div class="py-2">
      <text class="text-lg">
        <b>Research Interests |</b> Long-read Sequencing · Neuropsychiatric · Multi-omics · Omics-AI Integration · Molecular Biology
      </text>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Ongoing Projects</div>
  </div>

  {
    projects.map((project, i) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.img}
          desc={project.desc}
          url={project.url}
          badge={project.badge}
        />
        {i < projects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  {
    latest_product && (
      <>
        <div>
          <div class="text-3xl w-full font-bold mb-5 mt-10">Latest Product</div>
        </div>
        <HorizontalCard
          title={latest_product.title}
          img={latest_product.img}
          desc={latest_product.desc}
          url={latest_product.url}
          badge={latest_product.badge}
        />
      </>
    )
  }

  {
    latest_post && (
      <>
        <div>
          <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from Blog</div>
        </div>
        <HorizontalCard
          title={latest_post.data.title}
          img={latest_post.data.heroImage}
          desc={latest_post.data.description}
          url={"/blog/" + createSlug(latest_post.data.title, latest_post.slug)}
          target="_self"
          badge={latest_post.data.badge}
        />
      </>
    )
  }
</BaseLayout>
